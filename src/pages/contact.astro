---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';

const canonical = 'https://mendiak.github.io/pulse.roots/contact/';
---

<BaseLayout
  title="Contact - PulseRoots"
  description="Suggest a new electronic music genre, report an error, or send feedback about PulseRoots - the interactive music tree visualization."
  canonical={canonical}
>
  <div class="container">
    <h2><i class="bi bi-envelope" aria-hidden="true"></i> Contact Me</h2>
    <p>Got any cool ideas for the site, spotted a bug, or just wanna say hi? Don't be shy, drop me a line! I'd love to hear from you.</p>

    <form action="https://api.web3forms.com/submit" method="POST">
      <input type="hidden" name="access_key" value="41398cfd-0efd-45fa-859e-50b9e66d6f31">
      <input type="text" name="name" required placeholder="Your Name...">
      <input type="email" name="email" required placeholder="Your Email...">
      <select name="subject" id="subject-select" required>
        <option value="" disabled selected>Select a subject...</option>
        <option value="Suggestion">Suggest a New Genre</option>
        <option value="Error Report">Report an Error / Fix</option>
        <option value="General">General Inquiry</option>
        <option value="Other">Other</option>
      </select>
      <textarea name="message" required placeholder="Your Message..."></textarea>
      <input type="checkbox" name="botcheck" class="hidden" style="display: none;">
      <input type="hidden" name="redirect" value="https://mendiak.github.io/pulse.roots/thanks/">
      <button id="submitbutton" type="submit"><i class="bi bi-send"></i> <span>Submit</span></button>
    </form>

    <p style="text-align: center; margin-top: 30px;"><a href="/pulse.roots/" class="back-button">Back to PulseRoots</a></p>
  </div>

  <Footer />

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const urlParams = new URLSearchParams(window.location.search);
      const genre = urlParams.get('genre');
      const subjectParam = urlParams.get('subject');
      const messageArea = document.querySelector('textarea[name="message"]');
      const subjectSelect = document.getElementById('subject-select');
      if (subjectParam && subjectSelect) {
        for (let i = 0; i < subjectSelect.options.length; i++) {
          if (subjectSelect.options[i].value === subjectParam) { subjectSelect.selectedIndex = i; break; }
        }
      }
      if (genre && messageArea) {
        const decodedGenre = decodeURIComponent(genre);
        messageArea.value = subjectParam === 'Error Report'
          ? `Hi! I found an error in the genre "${decodedGenre}": \n\n[Please describe the error here...]`
          : `Hi! I have a suggestion regarding "${decodedGenre}": \n\n[Your suggestion here...]`;
      }
    });
  </script>

  <style>
    body { font-family: "Outfit", "Aleo", sans-serif; color: var(--text-main); background-color: var(--bg-dark); line-height: 1.6; min-height: 100vh; }
    .container { background: var(--panel-dark); backdrop-filter: var(--glass-blur); border: 1px solid var(--glass-border); border-radius: 16px; padding: 40px; margin: 40px auto; box-shadow: var(--shadow-lg); width: 100%; max-width: 600px; }
    h2 { color: var(--text-main); margin-top: 0; font-size: 1.75rem; display: flex; align-items: center; gap: 12px; }
    h2 i { color: var(--accent-pink); }
    p { color: var(--text-muted); }
    .back-button { display: inline-block; margin-top: 30px; padding: 10px 20px; background: var(--accent-gradient); color: white; border-radius: 8px; text-decoration: none; transition: all 0.3s ease; text-align: center; }
    .back-button:hover { transform: translateY(-2px); filter: brightness(1.1); box-shadow: 0 0 15px rgba(255, 0, 85, 0.5); }
  </style>
</BaseLayout>
