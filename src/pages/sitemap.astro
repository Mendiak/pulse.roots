---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'fs';
import path from 'path';

const canonical = 'https://mendiak.github.io/pulse.roots/sitemap/';

function slugify(text) {
  if (!text) return '';
  return text.toString().toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/\//g, '-')
    .replace(/[^\w\-]+/g, '')
    .replace(/\-\-+/g, '-')
    .replace(/^-+/, '')
    .replace(/-+$/, '');
}

const baseUrl = 'https://mendiak.github.io/pulse.roots';
let genreLinks = '';

try {
  const filePath = path.resolve(process.cwd(), 'data', 'pulseroots.genres.json');
  if (fs.existsSync(filePath)) {
    const data = JSON.parse(fs.readFileSync(filePath, 'utf-8'));

    const allGenres = [];
    const traverse = (items, slugParts, depth) => {
      for (const item of items) {
        const name = item.name || item.style;
        if (!name) continue;
        const slug = slugify(name);
        const fullSlugPath = [...slugParts, slug].join('/');
        allGenres.push({ genreName: name, fullSlugPath, depth });
        if (item.substyles && item.substyles.length > 0) {
          traverse(item.substyles, [...slugParts, slug], depth + 1);
        }
      }
    };
    traverse(data, [], 0);

    genreLinks = allGenres.map(g => {
      const url = `${baseUrl}/genres/${g.fullSlugPath}/`;
      const indent = g.depth > 0 ? '  '.repeat(g.depth) : '';
      return `${indent}<li><a href="${url}">${g.genreName}</a></li>`;
    }).join('\n    ');
  }
} catch (e) {
  console.error('Error loading genre data for sitemap:', e);
}
---

<BaseLayout
  title="Sitemap - PulseRoots"
  description="Sitemap of PulseRoots - an interactive visualization of electronic music genres. Browse all available genre pages."
  canonical={canonical}
>
  <header>
    <div id="header-container">
      <a href="/pulse.roots/" id="logo-link" aria-label="Home">
        <h1>PulseRoots - Sitemap</h1>
      </a>
    </div>
  </header>
  <main>
    <div id="main-container" style="padding: 20px; max-width: 800px; margin: 0 auto;">
      <h2>All Pages</h2>
      <ul>
        <li><a href="https://mendiak.github.io/pulse.roots/">Home</a></li>
        <li><a href="https://mendiak.github.io/pulse.roots/contact/">Contact</a></li>
        <li><a href="https://mendiak.github.io/pulse.roots/privacy/">Privacy Policy</a></li>
        <li><a href="https://mendiak.github.io/pulse.roots/thanks/">Thanks</a></li>
      </ul>
      <h2>All Genres</h2>
      <ul>
        {genreLinks}
      </ul>
    </div>
  </main>
  <footer>
    <div class="footer-bottom">
      <p>&copy; 2026 PulseRoots. Mapping the pulse of electronic music.</p>
    </div>
  </footer>
</BaseLayout>
